+
+static int iwl_pcie_load_payloads_segments(struct iwl_trans *trans,
+   struct iwl_dram_regions *dram_regions,
+   const struct iwl_pnvm_chunked_pkg *pkg)
+{
+struct iwl_prph_scratch_mem_desc_addr_array *addresses;
+struct iwl_prph_scratch_mem_desc_addr_array empty_desc = {};
+u32 n_chunks = le32_to_cpu(pkg->n_chunks);
+u32 i, offset = 0, len;

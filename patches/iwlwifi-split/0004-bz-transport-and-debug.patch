+static int iwl_pcie_load_payloads_contig(struct iwl_trans *trans,
+ const struct iwl_pnvm_chunked_pkg *pkg,
+ struct iwl_dram_data *dram)
+{
+u32 len0, len1, len;
+
+if (le32_to_cpu(pkg->n_chunks) != 2) {
+IWL_DEBUG_FW(trans, "expected 2 payloads, got %u.\n",
+     le32_to_cpu(pkg->n_chunks));
+return -EINVAL;
+}
+
+len0 = le32_to_cpu(pkg->chunk_len[0]);
+len1 = le32_to_cpu(pkg->chunk_len[1]);
+if (len1 > U32_MAX - len0) {
+IWL_DEBUG_FW(trans, "sizes of payloads overflow.\n");
+return -EINVAL;
+}
+
+len = len0 + len1;
+
+return iwl_pcie_ctxt_info_alloc_dma(trans, pkg->data, len, dram);

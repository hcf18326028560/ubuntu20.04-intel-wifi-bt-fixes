+static void iwl_pcie_free_dram_regions(struct device *dev,
+       struct iwl_dram_regions *dram_regions)
+{
+u32 i;
+
+if (dram_regions->prph_scratch_mem_desc.size)
+dma_free_coherent(dev,
+  dram_regions->prph_scratch_mem_desc.size,
+  dram_regions->prph_scratch_mem_desc.block,
+  dram_regions->prph_scratch_mem_desc.physical);
+
+for (i = 0; i < dram_regions->n_regions; i++) {
+if (!dram_regions->drams[i].size)
+continue;
+
+dma_free_coherent(dev, dram_regions->drams[i].size,
+  dram_regions->drams[i].block,
+  dram_regions->drams[i].physical);
+}
+
+memset(dram_regions, 0, sizeof(*dram_regions));
+}
+
+static int iwl_pcie_load_payloads_contig(struct iwl_trans *trans,
+ const struct iwl_pnvm_chunked_pkg *pkg,
+ struct iwl_dram_data *dram)
+{
+u32 len0, len1, len;
+
+if (le32_to_cpu(pkg->n_chunks) != 2) {
+IWL_DEBUG_FW(trans, "expected 2 payloads, got %u.\n",
+     le32_to_cpu(pkg->n_chunks));
+return -EINVAL;
+}
+
+len0 = le32_to_cpu(pkg->chunk_len[0]);
+len1 = le32_to_cpu(pkg->chunk_len[1]);
+if (len1 > U32_MAX - len0) {
+IWL_DEBUG_FW(trans, "sizes of payloads overflow.\n");
+return -EINVAL;
+}
+
+len = len0 + len1;
+
+return iwl_pcie_ctxt_info_alloc_dma(trans, pkg->data, len, dram);
+}
+
+static int iwl_pcie_load_payloads_segments(struct iwl_trans *trans,
+   struct iwl_dram_regions *dram_regions,
+   const struct iwl_pnvm_chunked_pkg *pkg)
+{
+struct iwl_prph_scratch_mem_desc_addr_array *addresses;
+struct iwl_prph_scratch_mem_desc_addr_array empty_desc = {};
+u32 n_chunks = le32_to_cpu(pkg->n_chunks);
+u32 i, offset = 0, len;
+
+len = sizeof(empty_desc);
+if (iwl_pcie_ctxt_info_alloc_dma(trans, &empty_desc, len,
+ &dram_regions->prph_scratch_mem_desc)) {
+IWL_DEBUG_FW(trans, "Failed to allocate PNVM DMA.\n");
+return -ENOMEM;
+}
+
+for (i = 0; i < n_chunks; i++) {
+len = le32_to_cpu(pkg->chunk_len[i]);
+if (iwl_pcie_ctxt_info_alloc_dma(trans, pkg->data + offset, len,
+ &dram_regions->drams[i])) {
+iwl_pcie_free_dram_regions(trans->dev, dram_regions);
+return -ENOMEM;
+}
+
+dram_regions->n_regions++;
+offset += len;
+}
+
+addresses = dram_regions->prph_scratch_mem_desc.block;
+for (i = 0; i < n_chunks; i++)
+addresses->mem_descs[i] =
+cpu_to_le64(dram_regions->drams[i].physical);
+
+return 0;
+}
+
+static size_t iwl_dram_regions_size(const struct iwl_dram_regions *dram_regions)
+{
+size_t total_size = 0;
+u32 i;
+
+for (i = 0; i < dram_regions->n_regions; i++)
+total_size += dram_regions->drams[i].size;
+
+return total_size;
+}

+			cfg->v5.psd_20 = IEEE80211_RNR_TBTT_PARAMS_PSD_RESERVED;
+			cfg->v5.iter_count = 1;
+			cfg->v5.iter_interval = 0;
+			cp->count++;
+		}
+	}
+}
